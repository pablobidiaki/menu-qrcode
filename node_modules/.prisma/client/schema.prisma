generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Order {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  items     Json
  table     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Table {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  orders      Json
  tableNumber Int
  total       Float
  isInUse     Boolean
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Sandwich {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  description    String
  price          Float
  promotionPrice Float?
  ingredients    Json
  images         String[]
  type           String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SideDishes {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  description    String
  size           String
  price          Float
  promotionPrice Float?
  images         String[]
  type           String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Drinks {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  description    String
  price          Float
  promotionPrice Float?
  images         String[]
  isAlcoholic    Boolean
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Dessert {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  description    String
  price          Float
  promotionPrice Float?
  images         String[]
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
